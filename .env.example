# --- Strava API application (https://www.strava.com/settings/api) ---
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Full callback URL. The Strava app's "Authorization Callback Domain" must match the host.
STRAVA_REDIRECT_URI=http://localhost:3000/api/auth/callback

# --- Stadia Maps (https://client.stadiamaps.com/signup/) ---
# OPTIONAL. With a key, rides render on a real base map. Without it (or on any
# failure / rate limit), the app falls back to drawing the route on a styled background.
STADIA_API_KEY=

# --- App ---
# 32+ random chars. Generate with: openssl rand -base64 32
SESSION_SECRET=
APP_BASE_URL=http://localhost:3000
