# --- Strava API application (https://www.strava.com/settings/api) ---
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Full callback URL. The Strava app's "Authorization Callback Domain" must match the host.
STRAVA_REDIRECT_URI=http://localhost:3000/api/auth/callback

# --- Mapbox (https://account.mapbox.com/) ---
MAPBOX_TOKEN=

# --- App ---
# 32+ random chars. Generate with: openssl rand -base64 32
SESSION_SECRET=
APP_BASE_URL=http://localhost:3000
